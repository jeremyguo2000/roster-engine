FROM node:20-alpine

WORKDIR /app

# Run as host user so generated files (lockfiles, build output) keep host ownership.
# Override at build time: docker compose build --build-arg USER_ID=$(id -u) --build-arg GROUP_ID=$(id -g)
ARG USER_ID=1000
ARG GROUP_ID=1000
RUN deluser --remove-home node 2>/dev/null || true \
    && addgroup -g ${GROUP_ID} appuser \
    && adduser -D -u ${USER_ID} -G appuser appuser \
    && chown -R appuser:appuser /app

COPY --chown=appuser:appuser package.json package-lock.json* ./
USER appuser
RUN npm install

EXPOSE 5173

# Source mounted as volume in dev; node_modules kept inside container.
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
